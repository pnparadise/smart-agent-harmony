{
  "module": {
    "name": "entry",
    "type": "entry",
    "srcEntry": "./ets/entryability/EntryAbilityStage.ets",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:entry_desc",
        "icon": "$media:app_icon",
        "label": "$string:app_name",
        "startWindowIcon": "$media:app_start_icon",
        "startWindowBackground": "$color:start_window_background",
        "orientation": "auto_rotation",
        "backgroundModes": [
          "dataTransfer"
        ],
        "exported": true,
        "skills": [
          {
            "actions": [
              "ohos.want.action.home"
            ],
            "entities": [
              "entity.system.home"
            ]
          }
        ],
        "metadata": [
          {
            "name": "ohos.ability.shortcuts",
            "resource": "$profile:shortcuts_config"
          }
        ]
      },
      {
        "name": "WebShortcutAbility",
        "srcEntry": "./ets/entryability/WebShortcutAbility.ets",
        "description": "$string:entry_desc",
        "icon": "$media:app_icon",
        "label": "$string:web_shortcut_label",
        "startWindowIcon": "$media:ic_web_shortcut_start_blank",
        "startWindowBackground": "$color:web_shortcut_start_window_background",
        "orientation": "auto_rotation",
        "exported": true,
        "launchType": "specified"
      }
    ],
    "extensionAbilities": [
      {
        "name": "WgVpnExtensionAbility",
        "srcEntry": "./ets/vpnextension/WgVpnExtensionAbility.ets",
        "type": "vpn",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.vpn.config",
            "resource": "$profile:vpn_config"
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.KEEP_BACKGROUND_RUNNING"
      }
    ]
  }
}
